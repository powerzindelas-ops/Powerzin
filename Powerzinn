-- BOLINHA PowerScript (RGB, arrastável, cai do céu)
-- ============================================
local function createPowerScriptBall()
    local ball = Instance.new("TextButton")
    ball.Name = "PowerScriptBall"
    ball.Size = UDim2.new(0, 70, 0, 70)
    ball.Position = UDim2.new(0.5, -35, -0.1, 0)
    ball.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    ball.Text = "Power\nScript"
    ball.TextColor3 = Color3.fromRGB(255, 255, 255)
    ball.TextScaled = true
    ball.Font = Enum.Font.GothamBold
    ball.ZIndex = 50
    ball.Parent = ScreenGui
    ball.AutoButtonColor = false

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ball

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 2
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Parent = ball

    TweenService:Create(ball, TweenInfo.new(1.5, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, -35, 0.85, 0)
    }):Play()

    spawn(function()
        local t = 0
        while ball.Parent do
            t = t + 0.03
            ball.BackgroundColor3 = getRGBColor(t)
            stroke.Color = getRGBColor(t + 1)
            wait()
        end
    end)

    makeDraggable(ball)
    return ball
end

