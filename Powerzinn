    plCorner.Parent = playerListFrame

    local playerListScroll = Instance.new("ScrollingFrame")
    playerListScroll.Size = UDim2.new(1, -4, 1, -4)
    playerListScroll.Position = UDim2.new(0, 2, 0, 2)
    playerListScroll.BackgroundTransparency = 1
    playerListScroll.ScrollBarThickness = 3
    playerListScroll.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 255)
    playerListScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    playerListScroll.ZIndex = 63
    playerListScroll.Parent = playerListFrame

    jy = jy + 145

    -- Info do jogador selecionado
    jy = createSectionInPage(jogPage, jy, "JOGADOR SELECIONADO")

    local selectedLabel
    selectedLabel, jy = createLabelInPage(jogPage, jy, "Nenhum jogador selecionado")

    -- Avatar
    local avatarImage = Instance.new("ImageLabel")
    avatarImage.Size = UDim2.new(0, 55, 0, 55)
    avatarImage.Position = UDim2.new(0, 3, 0, jy)
    avatarImage.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    avatarImage.ZIndex = 63
    avatarImage.Visible = false
    avatarImage.Parent = jogPage

    local avCorner = Instance.new("UICorner")
    avCorner.CornerRadius = UDim.new(0, 27)
    avCorner.Parent = avatarImage

    local pNameLabel = Instance.new("TextLabel")
    pNameLabel.Size = UDim2.new(0.6, 0, 0, 16)
    pNameLabel.Position = UDim2.new(0, 65, 0, jy)
    pNameLabel.BackgroundTransparency = 1
    pNameLabel.Text = ""
    pNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    pNameLabel.TextXAlignment = Enum.TextXAlignment.Left
    pNameLabel.Font = Enum.Font.GothamBold
    pNameLabel.TextSize = 11
    pNameLabel.ZIndex = 63
    pNameLabel.Parent = jogPage

    local pDisplayLabel = Instance.new("TextLabel")
    pDisplayLabel.Size = UDim2.new(0.6, 0, 0, 16)
    pDisplayLabel.Position = UDim2.new(0, 65, 0, jy + 16)
    pDisplayLabel.BackgroundTransparency = 1
    pDisplayLabel.Text = ""
    pDisplayLabel.TextColor3 = Color3.fromRGB(180, 180, 200)
    pDisplayLabel.TextXAlignment = Enum.TextXAlignment.Left
    pDisplayLabel.Font = Enum.Font.Gotham
    pDisplayLabel.TextSize = 10
    pDisplayLabel.ZIndex = 63
    pDisplayLabel.Parent = jogPage

    local pHealthLabel = Instance.new("TextLabel")
    pHealthLabel.Size = UDim2.new(0.6, 0, 0, 16)
    pHealthLabel.Position = UDim2.new(0, 65, 0, jy + 32)
    pHealthLabel.BackgroundTransparency = 1
    pHealthLabel.Text = ""
    pHealthLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    pHealthLabel.TextXAlignment = Enum.TextXAlignment.Left
    pHealthLabel.Font = Enum.Font.Gotham
    pHealthLabel.TextSize = 10
    pHealthLabel.ZIndex = 63
    pHealthLabel.Parent = jogPage

    jy = jy + 60

    -- Botões de ação
    local tpToPlayerBtn
    tpToPlayerBtn, jy = createButtonInPage(jogPage, jy, "Teleportar para o Player", Color3.fromRGB(0, 120, 200))

    local pullPlayerBtn
    pullPlayerBtn, jy = createButtonInPage(jogPage, jy, "Puxar Player", Color3.fromRGB(200, 120, 0))

    -- Espiar (toggle)
    local spyPlayerBtn = Instance.new("TextButton")
    spyPlayerBtn.Size = UDim2.new(1, -6, 0, 26)
    spyPlayerBtn.Position = UDim2.new(0, 3, 0, jy)
    spyPlayerBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
    spyPlayerBtn.Text = "Espiar Player"
    spyPlayerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    spyPlayerBtn.Font = Enum.Font.GothamBold
    spyPlayerBtn.TextSize = 11
    spyPlayerBtn.ZIndex = 62
    spyPlayerBtn.Parent = jogPage

    local spyCorner = Instance.new("UICorner")
    spyCorner.CornerRadius = UDim.new(0, 6)
    spyCorner.Parent = spyPlayerBtn

    jy = jy + 30

    -- Kill
    local killBtn
    killBtn, jy = createButtonInPage(jogPage, jy, "Kill Jogador", Color3.fromRGB(200, 0, 0))

    jogPage.CanvasSize = UDim2.new(0, 0, 0, jy + 10)

    -- ============================================
    -- LÓGICA DA LISTA DE JOGADORES
    -- ============================================
    local function refreshPlayerList()
        for _, child in pairs(playerListScroll:GetChildren()) do
            child:Destroy()
        end

        local players = Players:GetPlayers()
        local ly = 0

        for _, player in pairs(players) do
            if player ~= LocalPlayer then
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -4, 0, 24)
                btn.Position = UDim2.new(0, 2, 0, ly)
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
                btn.Text = player.Name .. " (" .. player.DisplayName .. ")"
                btn.TextColor3 = Color3.fromRGB(200, 200, 220)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.ZIndex = 64
                btn.Parent = playerListScroll

                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 4)
                btnCorner.Parent = btn

                btn.MouseButton1Click:Connect(function()
                    selectedPlayer = player
                    selectedLabel.Text = "Selecionado: " .. player.Name

                    avatarImage.Visible = true
                    pNameLabel.Text = "Nome: " .. player.Name
                    pDisplayLabel.Text = "Display: " .. player.DisplayName

                    pcall(function()
                        local thumbType = Enum.ThumbnailType.HeadShot
                        local thumbSize = Enum.ThumbnailSize.Size150x150
                        local content, isReady = Players:GetUserThumbnailAsync(player.UserId, thumbType, thumbSize)
                        avatarImage.Image = content
                    end)

                    pcall(function()
                        local char = player.Character
                        if char then
                            local h = char:FindFirstChildOfClass("Humanoid")
                            if h then
                                pHealthLabel.Text = "Vida: " .. math.floor(h.Health) .. "/" .. math.floor(h.MaxHealth)
                            end
                        end
                    end)

                    -- Destacar botão selecionado
                    for _, c in pairs(playerListScroll:GetChildren()) do
                        if c:IsA("TextButton") then
                            c.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
                        end
                    end
                    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 200)
                end)

                ly = ly + 26
            end
        end

        playerListScroll.CanvasSize = UDim2.new(0, 0, 0, ly)
    end

    -- Atualizar lista ao abrir a aba
    tabButtons["Jogadores"].MouseButton1Click:Connect(function()
        refreshPlayerList()
    end)

    -- Atualizar vida do selecionado em tempo real
    spawn(function()
        while true do
            if selectedPlayer then
                pcall(function()
                    local char = selectedPlayer.Character
                    if char then
                        local h = char:FindFirstChildOfClass("Humanoid")
                        if h then
                            pHealthLabel.Text = "Vida: " .. math.floor(h.Health) .. "/" .. math.floor(h.MaxHealth)
                        end
                    end
                end)
            end
            wait(0.5)
        end
    end)

    -- Teleportar para o player
    tpToPlayerBtn.MouseButton1Click:Connect(function()
        if selectedPlayer and selectedPlayer.Character then
            local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myHRP = getHRP()
            if targetHRP and myHRP then
                myHRP.CFrame = targetHRP.CFrame + Vector3.new(3, 0, 0)
            end
        end
    end)

    -- Puxar Player (traz o player até você)
    pullPlayerBtn.MouseButton1Click:Connect(function()
        if selectedPlayer and selectedPlayer.Character then
            local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myHRP = getHRP()
            if targetHRP and myHRP then
                targetHRP.CFrame = myHRP.CFrame + Vector3.new(3, 0, 0)
            end
        end
    end)

    -- Espiar Player (toggle)
    local spyConnection = nil

    spyPlayerBtn.MouseButton1Click:Connect(function()
        spyEnabled = not spyEnabled

        if spyEnabled then
            spyPlayerBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
            spyPlayerBtn.Text = "Parar de Espiar"

            if selectedPlayer and selectedPlayer.Character then
                spyTarget = selectedPlayer
                Camera.CameraSubject = selectedPlayer.Character:FindFirstChildOfClass("Humanoid")

                spyConnection = RunService.RenderStepped:Connect(function()
                    if not spyEnabled or not spyTarget or not spyTarget.Character then
                        if spyConnection then
                            spyConnection:Disconnect()
                            spyConnection = nil
                        end
                        pcall(function()
                            Camera.CameraSubject = getHumanoid()
                        end)
                        spyEnabled = false
                        spyPlayerBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
                        spyPlayerBtn.Text = "Espiar Player"
                        return
                    end
                end)
            end
        else
            spyPlayerBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
            spyPlayerBtn.Text = "Espiar Player"

            if spyConnection then
                spyConnection:Disconnect()
                spyConnection = nil
            end

            pcall(function()
                Camera.CameraSubject = getHumanoid()
            end)
            spyTarget = nil
        end
    end)

    -- Kill jogador
    killBtn.MouseButton1Click:Connect(function()
        if selectedPlayer and selectedPlayer.Character then
            pcall(function()
                local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    targetHRP.CFrame = CFrame.new(0, -500, 0)
                end
            end)
            pcall(function()
                local h = selectedPlayer.Character:FindFirstChildOfClass("Humanoid")
                if h then
                    h.Health = 0
                end
            end)
            pcall(function()
                local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(0, -5000, 0)
                    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bv.Parent = targetHRP
                    game:GetService("Debris"):AddItem(bv, 2)
                end
            end)
        end
    end)

    -- Abrir na primeira aba por padrão
    switchTab("Player")

    return mainFrame
end

